# SPECTRE Relayer Configuration
# Copy this to .env and fill in your values

# Solana RPC endpoint
RPC_URL=https://api.devnet.solana.com

# Relayer wallet secret key (base58)
# Generate with: solana-keygen new --outfile relayer.json
# Then convert: node -e "console.log(require('bs58').encode(Buffer.from(require('./relayer.json'))))"
RELAYER_SECRET=

# SPECTRE Program ID (update after anchor deploy)
PROGRAM_ID=CGGCXL7QsD2MeMnFNqsGroZkTN3TXtc3iVDUcFa4UgUh

# Server config
PORT=8787
BIND=0.0.0.0

# Fee config (basis points)
RELAYER_FEE_BPS=15
GAS_BUFFER=5000000
